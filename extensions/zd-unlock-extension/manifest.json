{
  "manifest_version": 3,
  "name": "CS Bot ZD Unlock",
  "version": "1.0.0",
  "description": "Poll CS Bot unlock commands and call the 9site SMS unlock endpoint.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://arcshelp.zeabur.app/*",
    "https://9sitebg.mvj4e7.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://9sitebg.mvj4e7.com/*"],
      "js": ["page_auth.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CS Bot ZD Unlock"
  }
}
