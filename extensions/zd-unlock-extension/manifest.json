{
  "manifest_version": 3,
  "name": "CS Bot Unlock",
  "version": "1.2.17",
  "description": "Poll CS Bot commands, call backend endpoints, and record backend API flows.",
  "permissions": ["alarms", "storage", "notifications", "tabs"],
  "host_permissions": [
    "https://cshelp.zeabur.app/*",
    "https://9sitebg.mvj4e7.com/*",
    "https://6sitebg.oj61i4.com/*",
    "https://merchant-own-backstage.dbsportxxxwo8.com/*",
    "https://api-merchant-backstage.dbsportxxxwo8.com/*",
    "https://*.dbsportxxxwo8.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://9sitebg.mvj4e7.com/*", "https://6sitebg.oj61i4.com/*", "https://merchant-own-backstage.dbsportxxxwo8.com/*", "https://*.dbsportxxxwo8.com/*"],
      "js": ["page_recorder_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://9sitebg.mvj4e7.com/*", "https://6sitebg.oj61i4.com/*", "https://merchant-own-backstage.dbsportxxxwo8.com/*", "https://*.dbsportxxxwo8.com/*"],
      "js": ["page_auth.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CS Bot Unlock"
  }
}
